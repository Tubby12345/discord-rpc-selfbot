{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "install": {
      "commands": [
        { "src": "package.json", "dest": "package.json" },
        { "src": "package-lock.json", "dest": "package-lock.json" },
        { "cmd": "npm install --include=dev", "customName": "Install dependencies with dev" }
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        { "src": "src", "dest": "src" },
        { "src": "tsconfig.json", "dest": "tsconfig.json" },
        { "cmd": "npm run build", "customName": "Build TypeScript" }
      ],
      "deployOutputs": [
        {
          "include": ["dist", "package.json", "package-lock.json"],
          "exclude": ["node_modules", "src"]
        }
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
